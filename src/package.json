{
  "name": "thermalsight",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.edu.thermalsight",
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "../backend/dist/analyzer",
        "to": "backend"
      }
    ],
    "mac": { "target": "dmg" },
    "win": { "target": "nsis" },
    "linux": { "target": "AppImage" }
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^8.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "vite": "^8.0.12",
    "wait-on": "^7.0.1"
  }
}